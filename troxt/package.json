{
  "name": "troxt",
  "version": "0.1.0",
  "description": "Personal agent for EtherWorld — replaces @blinkdotnew/* in engine-lab",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./ui": "./src/troxt/ui-bridge.tsx",
    "./contracts": "./src/contracts/index.ts",
    "./engines/*": "./src/engines/*/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "test": "vitest"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "three": "^0.160.0",
    "@react-three/fiber": "^8.0.0"
  },
  "optionalDependencies": {
    "@tensorflow/tfjs": "^4.20.0",
    "@tensorflow/tfjs-backend-webgl": "^4.20.0",
    "@tensorflow-models/pose-detection": "^2.1.0",
    "@tensorflow-models/body-segmentation": "^1.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/react": "^18.0.0",
    "@types/three": "^0.160.0",
    "vitest": "^4.1.9"
  }
}
